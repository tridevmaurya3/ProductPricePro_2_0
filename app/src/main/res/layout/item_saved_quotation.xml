<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_saved_quotation"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="18dp"
    app:cardElevation="1dp"
    app:strokeColor="#D7E1D9"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- TITLE AND STATUS -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="46dp"
                android:layout_height="46dp"
                app:cardBackgroundColor="#EAF7EE"
                app:cardCornerRadius="15dp"
                app:cardElevation="0dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:contentDescription="Saved quotation"
                    android:src="@drawable/ic_saved_quotations"
                    app:tint="#0F7A32" />

            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="11dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/text_saved_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:text="Customer Quotation"
                    android:textColor="#242424"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/text_saved_date"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="Saved on 21 Jul 2026, 09:30 PM"
                    android:textColor="#707070"
                    android:textSize="11sp" />

            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_saved_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                app:cardBackgroundColor="#FFF8E8"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="#E8D29A"
                app:strokeWidth="1dp">

                <TextView
                    android:id="@+id/text_saved_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="10dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="5dp"
                    android:text="DRAFT"
                    android:textColor="#80631D"
                    android:textSize="10sp"
                    android:textStyle="bold" />

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- CUSTOMER / SELF DETAILS -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#F7FBF8"
            app:cardCornerRadius="13dp"
            app:cardElevation="0dp"
            app:strokeColor="#D6E7DA"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="11dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="19dp"
                        android:layout_height="19dp"
                        android:contentDescription="Order for"
                        android:src="@drawable/ic_customer"
                        app:tint="#0F7A32" />

                    <TextView
                        android:id="@+id/text_saved_order_for"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="Order For: Self"
                        android:textColor="#145A2B"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_saved_mobile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="19dp"
                        android:layout_height="19dp"
                        android:contentDescription="Mobile number"
                        android:src="@drawable/ic_phone"
                        app:tint="#0F6CBD" />

                    <TextView
                        android:id="@+id/text_saved_mobile"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="+91 00000 00000"
                        android:textColor="#315F83"
                        android:textSize="12sp" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- TOTAL SUMMARY -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                app:cardBackgroundColor="#F5F5F5"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="#E1E1E1"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:minHeight="62dp"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Products"
                        android:textColor="#707070"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/text_saved_item_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0"
                        android:textColor="#242424"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                app:cardBackgroundColor="#EFFAF3"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="#A9DDBB"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:minHeight="62dp"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total VP"
                        android:textColor="#446D4B"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/text_saved_total_vp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0.00"
                        android:textColor="#107C10"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1.25"
                app:cardBackgroundColor="#EEF6FD"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="#B8D8F2"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:minHeight="62dp"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Grand Total"
                        android:textColor="#315F83"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/text_saved_grand_total"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center"
                        android:text="₹0"
                        android:textColor="#0F6CBD"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- INFORMATION NOTE -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_saved_notes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:visibility="gone"
            app:cardBackgroundColor="#FFFDF7"
            app:cardCornerRadius="9dp"
            app:cardElevation="0dp"
            app:strokeColor="#E8DFC1"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingTop="8dp"
                android:paddingEnd="10dp"
                android:paddingBottom="8dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="3dp"
                    android:layout_height="34dp"
                    app:cardBackgroundColor="#D39B00"
                    app:cardCornerRadius="2dp"
                    app:cardElevation="0dp" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginStart="9dp"
                    android:contentDescription="Quotation note"
                    android:src="@drawable/ic_note"
                    app:tint="#9A6B00" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NOTE"
                        android:textColor="#9A6B00"
                        android:textSize="9sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/text_saved_notes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:text="Quotation notes"
                        android:textColor="#5F563C"
                        android:textSize="11sp" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- STATUS ACTION -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_change_saved_status"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="11dp"
            android:gravity="center"
            android:text="Mark Final"
            android:textAllCaps="false"
            android:textColor="#80631D"
            android:textSize="12sp"
            app:backgroundTint="#FFF8E8"
            app:cornerRadius="23dp"
            app:icon="@drawable/ic_save"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            app:iconSize="18dp"
            app:iconTint="#80631D"
            app:strokeColor="#E8D29A"
            app:strokeWidth="1dp" />

        <!-- RENAME AND DUPLICATE ACTIONS -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="9dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_rename_saved_quotation"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:gravity="center"
                android:minWidth="0dp"
                android:text="Rename"
                android:textAllCaps="false"
                android:textColor="#0F6CBD"
                android:textSize="12sp"
                app:cornerRadius="23dp"
                app:icon="@drawable/ic_edit"
                app:iconGravity="textStart"
                app:iconPadding="5dp"
                app:iconSize="17dp"
                app:iconTint="#0F6CBD"
                app:strokeColor="#B8D8F2"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_duplicate_saved_quotation"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_marginStart="4dp"
                android:layout_weight="1.25"
                android:gravity="center"
                android:minWidth="0dp"
                android:text="Duplicate"
                android:textAllCaps="false"
                android:textColor="#6B4FA1"
                android:textSize="12sp"
                app:cornerRadius="23dp"
                app:icon="@drawable/ic_copy"
                app:iconGravity="textStart"
                app:iconPadding="5dp"
                app:iconSize="17dp"
                app:iconTint="#6B4FA1"
                app:strokeColor="#BDAFDC"
                app:strokeWidth="1dp" />

        </LinearLayout>

        <!-- MAIN ACTIONS -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="9dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_open_saved_quotation"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1.35"
                android:gravity="center"
                android:minWidth="0dp"
                android:text="Open"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                app:backgroundTint="#0F7A32"
                app:cornerRadius="24dp"
                app:icon="@drawable/ic_saved_quotations"
                app:iconGravity="textStart"
                app:iconPadding="5dp"
                app:iconSize="17dp"
                app:iconTint="@android:color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_share_saved_quotation"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:gravity="center"
                android:minWidth="0dp"
                android:text="Share"
                android:textAllCaps="false"
                android:textColor="#0F6CBD"
                android:textSize="12sp"
                app:cornerRadius="24dp"
                app:icon="@drawable/ic_share"
                app:iconGravity="textStart"
                app:iconPadding="4dp"
                app:iconSize="17dp"
                app:iconTint="#0F6CBD"
                app:strokeColor="#0F6CBD"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_delete_saved_quotation"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="4dp"
                android:contentDescription="Delete quotation"
                android:minWidth="0dp"
                android:padding="0dp"
                android:text=""
                app:cornerRadius="24dp"
                app:icon="@drawable/ic_delete"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="19dp"
                app:iconTint="#C42B1C"
                app:strokeColor="#C42B1C"
                app:strokeWidth="1dp" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>