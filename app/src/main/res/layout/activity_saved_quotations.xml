<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F8F4"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_saved_quotations"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#0F7A32"
        android:elevation="4dp"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="@android:color/white"
        app:subtitle="Drafts, final and sent quotations"
        app:subtitleTextColor="#DDF5E4"
        app:title="Saved Quotations"
        app:titleTextColor="@android:color/white" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <!-- HEADER CARD -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#EAF7EE"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="#B7DEC0"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    app:cardBackgroundColor="#D5EFDC"
                    app:cardCornerRadius="17dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:layout_width="27dp"
                        android:layout_height="27dp"
                        android:layout_gravity="center"
                        android:contentDescription="Saved quotations"
                        android:src="@drawable/ic_saved_quotations"
                        app:tint="#0F7A32" />

                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="13dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Your Saved Quotations"
                        android:textColor="#145A2B"
                        android:textSize="19sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="Open, manage and share saved quotations anytime."
                        android:textColor="#56705D"
                        android:textSize="12sp" />

                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#B7DEC0"
                    app:strokeWidth="1dp">

                    <TextView
                        android:id="@+id/text_saved_quotation_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:minWidth="44dp"
                        android:paddingStart="11dp"
                        android:paddingTop="7dp"
                        android:paddingEnd="11dp"
                        android:paddingBottom="7dp"
                        android:text="0"
                        android:textColor="#0F7A32"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- SEARCH -->

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layout_search_quotations"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:hint="Search quotation, customer or mobile"
            app:boxBackgroundColor="#FFFFFF"
            app:boxCornerRadiusBottomEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusTopStart="14dp"
            app:boxStrokeColor="#0F7A32"
            app:endIconMode="clear_text"
            app:startIconDrawable="@drawable/ic_search">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_search_quotations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="#242424"
                android:textSize="14sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- STATUS FILTER -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Filter by Status"
                android:textColor="#242424"
                android:textSize="13sp"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:clipToPadding="false"
                android:fillViewport="false"
                android:overScrollMode="never"
                android:scrollbars="none">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_quotation_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingEnd="4dp"
                    app:chipSpacingHorizontal="7dp"
                    app:selectionRequired="true"
                    app:singleLine="true"
                    app:singleSelection="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_filter_all"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:checkable="true"
                        android:text="All"
                        android:textSize="12sp"
                        app:checkedIconVisible="false"
                        app:chipIcon="@drawable/ic_saved_quotations"
                        app:chipIconSize="17dp"
                        app:chipIconTint="#0F7A32"
                        app:chipStrokeColor="#B7DEC0"
                        app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_filter_draft"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checkable="true"
                        android:text="Draft"
                        android:textSize="12sp"
                        app:checkedIconVisible="false"
                        app:chipStrokeColor="#E8D29A"
                        app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_filter_final"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checkable="true"
                        android:text="Final"
                        android:textSize="12sp"
                        app:checkedIconVisible="false"
                        app:chipStrokeColor="#B8D8F2"
                        app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_filter_sent"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checkable="true"
                        android:text="Sent"
                        android:textSize="12sp"
                        app:checkedIconVisible="false"
                        app:chipStrokeColor="#A9DDBB"
                        app:chipStrokeWidth="1dp" />

                </com.google.android.material.chip.ChipGroup>

            </HorizontalScrollView>

        </LinearLayout>

        <!-- LIST TITLE -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="13dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/text_saved_list_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="All Quotations"
                android:textColor="#242424"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_saved_list_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Newest first"
                android:textColor="#707070"
                android:textSize="11sp" />

        </LinearLayout>

        <!-- CONTENT CONTAINER -->

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="9dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_saved_quotations"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingBottom="12dp"
                android:visibility="gone" />

            <!-- EMPTY STATE -->

            <LinearLayout
                android:id="@+id/layout_saved_quotations_empty"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp"
                android:visibility="visible">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="76dp"
                    android:layout_height="76dp"
                    app:cardBackgroundColor="#EAF7EE"
                    app:cardCornerRadius="25dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#B7DEC0"
                    app:strokeWidth="1dp">

                    <ImageView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_gravity="center"
                        android:contentDescription="No saved quotations"
                        android:src="@drawable/ic_saved_quotations"
                        app:tint="#0F7A32" />

                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/text_saved_empty_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center"
                    android:text="No Saved Quotations"
                    android:textColor="#242424"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/text_saved_empty_message"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:text="Create an order and tap Save for Later. Your quotation will appear here."
                    android:textColor="#616161"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_empty_create_quotation"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="52dp"
                    android:layout_marginTop="20dp"
                    android:text="Create Quotation"
                    android:textAllCaps="false"
                    android:textColor="#0F7A32"
                    android:textSize="13sp"
                    app:cornerRadius="26dp"
                    app:icon="@drawable/ic_add"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp"
                    app:iconSize="18dp"
                    app:iconTint="#0F7A32"
                    app:strokeColor="#0F7A32"
                    app:strokeWidth="1dp" />

            </LinearLayout>

        </FrameLayout>

    </LinearLayout>

</LinearLayout>