<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/category_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="14dp"
    app:cardElevation="1dp"
    app:rippleColor="#E8F3E8"
    app:strokeColor="#E1E1E1"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="86dp"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingTop="12dp"
        android:paddingEnd="8dp"
        android:paddingBottom="12dp">

        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_category_icon" />

            <ImageView
                android:id="@+id/image_category_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="Category"
                android:src="@drawable/ic_category"
                app:tint="#107C10" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_category_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="Weight Management"
                android:textColor="#242424"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_category_product_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="0 products"
                android:textColor="#616161"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/text_category_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_status_active"
                android:paddingStart="9dp"
                android:paddingTop="3dp"
                android:paddingEnd="9dp"
                android:paddingBottom="3dp"
                android:text="Active"
                android:textColor="#107C10"
                android:textSize="11sp"
                android:textStyle="bold" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_edit_category"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:contentDescription="Edit category"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:padding="10dp"
            android:text=""
            app:icon="@drawable/ic_edit"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="20dp"
            app:iconTint="#0F6CBD"
            app:rippleColor="#E8F1FA" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_delete_category"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:contentDescription="Delete category"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:padding="10dp"
            android:text=""
            app:icon="@drawable/ic_delete"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="20dp"
            app:iconTint="#C42B1C"
            app:rippleColor="#FDE7E5" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>